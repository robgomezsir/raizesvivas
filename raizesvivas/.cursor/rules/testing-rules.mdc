# Regras de Testes - Raízes Vivas

## Estrutura de Testes (OBRIGATÓRIA)

### Cobertura Mínima
- **80%** para lógica de negócio
- **100%** para algoritmo de parentesco (OBRIGATÓRIO)
- **80%** para ViewModels
- **90%** para Use Cases

### Estrutura de Diretórios
```
src/
├── main/kotlin/...
└── test/kotlin/
    ├── algorithms/
    │   └── KinshipCalculatorTest.kt (100% cobertura!)
    ├── usecase/
    │   ├── AddMemberUseCaseTest.kt
    │   ├── CreateSubfamilyUseCaseTest.kt
    │   └── CalculateKinshipUseCaseTest.kt
    ├── repository/
    │   └── MemberRepositoryTest.kt
    └── viewmodel/
        └── AddMemberViewModelTest.kt
```

## Testes Unitários (PADRÃO)

### Teste de Use Case
```kotlin
@OptIn(ExperimentalCoroutinesApi::class)
class AddMemberUseCaseTest {
    
    @get:Rule
    val mainDispatcherRule = MainDispatcherRule()
    
    private lateinit var useCase: AddMemberUseCase
    private lateinit var repository: FakeMemberRepository
    private lateinit var validator: MemberValidator
    
    @Before
    fun setup() {
        repository = FakeMemberRepository()
        validator = MemberValidator()
        useCase = AddMemberUseCase(repository, validator)
    }
    
    @Test
    fun `invoke - dados válidos - retorna Success`() = runTest {
        // Arrange
        val member = Member(
            id = "test-id",
            fullName = "João Silva",
            birthDate = LocalDate.of(1990, 1, 1),
            generation = 0,
            treeElement = TreeElement.TRUNK
        )
        
        // Act
        val result = useCase(member)
        
        // Assert
        assertThat(result).isInstanceOf(Result.Success::class.java)
        val success = result as Result.Success
        assertThat(success.data.id).isEqualTo("test-id")
        assertThat(repository.members).contains(member)
    }
    
    @Test
    fun `invoke - nome vazio - retorna Error`() = runTest {
        // Arrange
        val member = Member(
            id = "test-id",
            fullName = "", // Nome vazio
            birthDate = LocalDate.of(1990, 1, 1),
            generation = 0,
            treeElement = TreeElement.TRUNK
        )
        
        // Act
        val result = useCase(member)
        
        // Assert
        assertThat(result).isInstanceOf(Result.Error::class.java)
        val error = result as Result.Error
        assertThat(error.exception).isInstanceOf(
            RaizesVivasException.InvalidDateException::class.java
        )
    }
    
    @Test
    fun `invoke - cria loop - retorna Error`() = runTest {
        // Arrange: A é pai de B
        val memberA = createMember(id = "A", generation = 0)
        val memberB = createMember(id = "B", generation = 1, fatherId = "A")
        repository.addMember(memberA)
        repository.addMember(memberB)
        
        // Act: Tentar fazer B pai de A (loop!)
        val memberAWithLoop = memberA.copy(fatherId = "B")
        val result = useCase(memberAWithLoop)
        
        // Assert
        assertThat(result).isInstanceOf(Result.Error::class.java)
        val error = result as Result.Error
        assertThat(error.exception).isInstanceOf(
            RaizesVivasException.GenealogicalLoopException::class.java
        )
    }
}
```

