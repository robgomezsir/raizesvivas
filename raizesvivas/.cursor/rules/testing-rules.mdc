## Testes de Integração

### Teste de Repository + Database
```kotlin
@RunWith(AndroidJUnit4::class)
class MemberRepositoryIntegrationTest {
    
    private lateinit var database: RaizesVivasDatabase
    private lateinit var repository: MemberRepositoryImpl
    
    @Before
    fun setup() {
        val context = ApplicationProvider.getApplicationContext<Context>()
        
        // Criar database in-memory para testes
        database = Room.inMemoryDatabaseBuilder(
            context,
            RaizesVivasDatabase::class.java
        ).build()
        
        repository = MemberRepositoryImpl(
            localSource = database.memberDao(),
            remoteSource = FakeSupabaseClient()
        )
    }
    
    @After
    fun tearDown() {
        database.close()
    }
    
    @Test
    fun addMember_savesToDatabase() = runTest {
        // Arrange
        val member = createTestMember()
        
        // Act
        repository.addMember(member)
        
        // Assert
        val retrieved = repository.getMember(member.id)
        assertThat(retrieved).isEqualTo(member)
    }
    
    @Test
    fun getMembersByFamily_returnsOnlyFamilyMembers() = runTest {
        // Arrange
        val family1Member = createTestMember(id = "1", familyId = "family1")
        val family2Member = createTestMember(id = "2", familyId = "family2")
        repository.addMember(family1Member)
        repository.addMember(family2Member)
        
        // Act
        val members = repository.getMembersByFamily("family1").first()
        
        // Assert
        assertThat(members).hasSize(1)
        assertThat(members[0].id).isEqualTo("1")
    }
}
```

## Testes do Algoritmo de Parentesco (100% COBERTURA)

### Testes Básicos
```kotlin
@OptIn(ExperimentalCoroutinesApi::class)
class KinshipCalculatorTest {
    
    @get:Rule
    val mainDispatcherRule = MainDispatcherRule()
    
    private lateinit var calculator: KinshipCalculator
    private lateinit var repository: FakeMemberRepository
    
    @Before
    fun setup() {
        repository = FakeMemberRepository()
        calculator = KinshipCalculator(repository)
    }
    
    @Test
    fun `calculate - pai e filho - retorna Parent`() = runTest {
        // Arrange
        val father = createMember(id = "1", generation = 0)
        val son = createMember(id = "2", generation = 1, fatherId = "1")
        repository.addMember(father)
        repository.addMember(son)
        
        // Act
        val result = calculator.calculate("1", "2", familyZeroId)
        
        // Assert
        assertTrue(result is Result.Success)
        val kinship = (result as Result.Success).data
        assertEquals(KinshipType.Parent, kinship.type)
        assertEquals(1, kinship.degree)
    }
    
    @Test
    fun `calculate - irmãos - retorna Sibling`() = runTest {
        // Arrange
        val brother1 = createMember(id = "1", generation = 1, fatherId = "f", motherId = "m")
        val brother2 = createMember(id = "2", generation = 1, fatherId = "f", motherId = "m")
        repository.addMember(brother1)
        repository.addMember(brother2)
        
        // Act
        val result = calculator.calculate("1", "2", familyZeroId)
        
        // Assert
        assertTrue(result is Result.Success)
        assertEquals(KinshipType.Sibling, (result as Result.Success).data.type)
    }
    
    @Test
    fun `calculate - primos de primeiro grau - retorna FirstCousin`() = runTest {
        // Arrange
        val grandfather = createMember(id = "gf", generation = -1)
        val uncle = createMember(id = "u", generation = 0, fatherId = "gf")
        val father = createMember(id = "f", generation = 0, fatherId = "gf")
        val me = createMember(id = "me", generation = 1, fatherId = "f")
        val cousin = createMember(id = "c", generation = 1, fatherId = "u")
        
        repository.addMember(grandfather)
        repository.addMember(uncle)
        repository.addMember(father)
        repository.addMember(me)
        repository.addMember(cousin)
        
        // Act
        val result = calculator.calculate("me", "c", familyZeroId)
        
        // Assert
        assertTrue(result is Result.Success)
        assertEquals(KinshipType.FirstCousin, (result as Result.Success).data.type)
    }
    
    @Test
    fun `calculate - loop genealógico - retorna erro`() = runTest {
        // Arrange: A é pai de B, B é pai de C, tentar fazer C pai de A
        val a = createMember(id = "a", generation = 0)
        val b = createMember(id = "b", generation = 1, fatherId = "a")
        val c = createMember(id = "c", generation = 2, fatherId = "b")
        
        repository.addMember(a)
        repository.addMember(b)
        repository.addMember(c)
        
        // Act
        val result = repository.addMember(
            a.copy(fatherId = "c") // Tentando criar loop
        )
        
        // Assert
        assertTrue(result is Result.Error)
        assertTrue(
            (result as Result.Error).exception 
            is RaizesVivasException.GenealogicalLoopException
        )
    }
    
    @Test
    fun `calculate - sem ancestral comum - retorna Unrelated`() = runTest {
        // Arrange: Duas árvores separadas
        val person1 = createMember(id = "1", generation = 0, fatherId = "f1")
        val person2 = createMember(id = "2", generation = 0, fatherId = "f2")
        
        repository.addMember(person1)
        repository.addMember(person2)
        
        // Act
        val result = calculator.calculate("1", "2", familyZeroId)
        
        // Assert
        assertTrue(result is Result.Success)
        assertEquals(Kinship.Unrelated, (result as Result.Success).data)
    }
    
    // ADICIONAR PELO MENOS 50 TESTES COBRINDO TODOS OS CASOS
}
```

