### DAO Example
```kotlin
@Dao
interface MemberDao {
    
    @Query("SELECT * FROM members WHERE familia_principal_id = :familyId")
    fun getMembersByFamily(familyId: String): Flow<List<MemberEntity>>
    
    @Query("SELECT * FROM members WHERE id = :memberId")
    suspend fun getMember(memberId: String): MemberEntity?
    
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertMember(member: MemberEntity)
    
    @Update
    suspend fun updateMember(member: MemberEntity)
    
    @Delete
    suspend fun deleteMember(member: MemberEntity)
    
    @Query("DELETE FROM members WHERE familia_principal_id = :familyId")
    suspend fun deleteMembersByFamily(familyId: String)
    
    /**
     * QUERY COMPLEXA: Buscar todos os ancestrais
     */
    @Query("""
        WITH RECURSIVE ancestors AS (
            SELECT * FROM members WHERE id = :memberId
            UNION ALL
            SELECT m.* FROM members m
            INNER JOIN ancestors a ON m.id = a.pai_id OR m.id = a.mae_id
        )
        SELECT * FROM ancestors WHERE id != :memberId
    """)
    suspend fun getAncestors(memberId: String): List<MemberEntity>
    
    /**
     * QUERY COMPLEXA: Buscar todos os descendentes
     */
    @Query("""
        WITH RECURSIVE descendants AS (
            SELECT * FROM members WHERE id = :memberId
            UNION ALL
            SELECT m.* FROM members m
            INNER JOIN descendants d ON m.pai_id = d.id OR m.mae_id = d.id
        )
        SELECT * FROM descendants WHERE id != :memberId
    """)
    suspend fun getDescendants(memberId: String): List<MemberEntity>
}
```

## Regras de Sincronização

### 1. Room deve espelhar Supabase
- **SEMPRE** manter estruturas sincronizadas
- **SEMPRE** usar mesmos nomes de campos
- **SEMPRE** manter constraints iguais

### 2. Mappers Obrigatórios
```kotlin
fun MemberEntity.toDomain(): Member {
    return Member(
        id = id,
        fullName = nomeCompleto,
        birthDate = dataNascimento?.let { LocalDate.ofEpochDay(it) },
        generation = geracaoNaFamiliaZero,
        treeElement = TreeElement.valueOf(elementoArvore)
    )
}

fun Member.toEntity(): MemberEntity {
    return MemberEntity(
        id = id,
        familiaPrincipalId = familyId,
        nomeCompleto = fullName,
        dataNascimento = birthDate?.toEpochDay(),
        geracaoNaFamiliaZero = generation,
        elementoArvore = treeElement.name
    )
}
```

### 3. Repository Pattern
```kotlin
class MemberRepositoryImpl @Inject constructor(
    private val localSource: MemberDao,
    private val remoteSource: SupabaseClient
) : MemberRepository {
    
    override suspend fun addMember(member: Member): Result<Member> {
        return try {
            // 1. Salvar localmente
            localSource.insertMember(member.toEntity())
            
            // 2. Sincronizar com Supabase
            val response = remoteSource.from("membros")
                .insert(member.toEntity())
                .execute()
            
            Result.Success(member)
        } catch (e: Exception) {
            Result.Error(RaizesVivasException.DatabaseException(e))
        }
    }
}
```

## Regras de Performance

### 1. Índices Obrigatórios
- **SEMPRE** criar índices em foreign keys
- **SEMPRE** criar índices em campos de busca
- **SEMPRE** usar índices compostos para queries complexas

### 2. Queries Otimizadas
- **NUNCA** fazer queries N+1
- **SEMPRE** usar LIMIT para listas grandes
- **SEMPRE** usar JOIN em vez de múltiplas queries

### 3. Cache Strategy
- **SEMPRE** cachear parentescos calculados
- **SEMPRE** invalidar cache ao modificar dados
- **SEMPRE** usar cache local para dados estáticos