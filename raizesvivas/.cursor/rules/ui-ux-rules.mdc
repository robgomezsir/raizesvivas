## Formulários e Validação

### Formulário de Adicionar Membro
```kotlin
@Composable
fun AddMemberForm(
    formState: AddMemberFormState,
    onEvent: (AddMemberEvent) -> Unit,
    modifier: Modifier = Modifier
) {
    Column(
        modifier = modifier
            .fillMaxWidth()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Nome
        OutlinedTextField(
            value = formState.name,
            onValueChange = { onEvent(AddMemberEvent.NameChanged(it)) },
            label = { Text("Nome completo") },
            isError = formState.nameError != null,
            supportingText = formState.nameError?.let { { Text(it) } },
            modifier = Modifier.fillMaxWidth()
        )
        
        // Data de nascimento
        val datePickerState = rememberDatePickerState()
        val showDatePicker = remember { mutableStateOf(false) }
        
        OutlinedTextField(
            value = formState.birthDate?.toString() ?: "",
            onValueChange = { },
            label = { Text("Data de nascimento") },
            readOnly = true,
            trailingIcon = {
                IconButton(onClick = { showDatePicker.value = true }) {
                    Icon(Icons.Default.DateRange, contentDescription = "Selecionar data")
                }
            },
            modifier = Modifier.fillMaxWidth()
        )
        
        // Botão de salvar
        Button(
            onClick = { onEvent(AddMemberEvent.Submit) },
            enabled = !formState.isSubmitting && formState.name.isNotBlank(),
            modifier = Modifier.fillMaxWidth()
        ) {
            if (formState.isSubmitting) {
                CircularProgressIndicator(
                    modifier = Modifier.size(16.dp),
                    strokeWidth = 2.dp
                )
                Spacer(Modifier.width(8.dp))
            }
            Text("Adicionar Membro")
        }
    }
}
```

## Navegação

### Navigation Setup
```kotlin
@Composable
fun RaizesVivasNavigation() {
    val navController = rememberNavController()
    
    NavHost(
        navController = navController,
        startDestination = "home"
    ) {
        composable("home") {
            HomeScreen(
                onNavigateToAddMember = {
                    navController.navigate("add_member")
                }
            )
        }
        
        composable("add_member") {
            AddMemberScreen(
                onNavigateBack = {
                    navController.popBackStack()
                }
            )
        }
    }
}
