# Regras de UI/UX - Raízes Vivas

## Componentes Reutilizáveis (OBRIGATÓRIOS)

### MemberCard
```kotlin
@Composable
fun MemberCard(
    member: Member,
    kinship: String?,
    onClick: () -> Unit,
    modifier: Modifier = Modifier
) {
    Card(
        modifier = modifier
            .fillMaxWidth()
            .clickable(onClick = onClick),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Row(
            modifier = Modifier
                .padding(16.dp)
                .fillMaxWidth(),
            verticalAlignment = Alignment.CenterVertically
        ) {
            // Foto
            AsyncImage(
                model = member.photoUrl,
                contentDescription = "Foto de ${member.fullName}",
                modifier = Modifier
                    .size(56.dp)
                    .clip(CircleShape),
                placeholder = painterResource(R.drawable.ic_person_placeholder),
                error = painterResource(R.drawable.ic_person_placeholder)
            )
            
            Spacer(modifier = Modifier.width(16.dp))
            
            // Informações
            Column(modifier = Modifier.weight(1f)) {
                Text(
                    text = member.fullName,
                    style = MaterialTheme.typography.titleMedium,
                    maxLines = 1,
                    overflow = TextOverflow.Ellipsis
                )
                
                if (kinship != null) {
                    Text(
                        text = kinship,
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.secondary
                    )
                }
                
                member.birthDate?.let { date ->
                    Text(
                        text = formatDate(date),
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
            }
            
            // Elemento da árvore
            TreeElementIcon(
                element = member.treeElement,
                modifier = Modifier.size(32.dp)
            )
        }
    }
}
```

### TreeElementIcon
```kotlin
@Composable
fun TreeElementIcon(
    element: TreeElement,
    modifier: Modifier = Modifier
) {
    val (icon, color) = when (element) {
        TreeElement.ROOT -> Icons.Default.Nature to Color(0xFF5D4037)
        TreeElement.BARK -> Icons.Default.AccountTree to Color(0xFF8D6E63)
        TreeElement.TRUNK -> Icons.Default.Park to Color(0xFFA1887F)
        TreeElement.BRANCH -> Icons.Default.CallSplit to Color(0xFF689F38)
        TreeElement.LEAF -> Icons.Default.Grass to Color(0xFF8BC34A)
        TreeElement.FLOWER -> Icons.Default.LocalFlorist to Color(0xFFE91E63)
        TreeElement.POLLINATOR -> Icons.Default.BugReport to Color(0xFFFFA726)
        TreeElement.BIRD -> Icons.Default.Flight to Color(0xFF42A5F5)
    }
    
    Icon(
        imageVector = icon,
        contentDescription = element.name,
        tint = color,
        modifier = modifier
    )
}
```

