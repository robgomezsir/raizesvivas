## Composables e Recomposition

### ✅ CORRETO: Minimizar recomposições
```kotlin
@Composable
fun FamilyTreeScreen(
    viewModel: FamilyTreeViewModel = hiltViewModel()
) {
    // ✅ CORRETO: Coletar state
    val treeState by viewModel.treeState.collectAsStateWithLifecycle()
    val selectedFamily by viewModel.selectedFamily.collectAsStateWithLifecycle()
    
    // ✅ CORRETO: Derivar estado complexo
    val filteredMembers = remember(treeState, selectedFamily) {
        derivedStateOf {
            when (val state = treeState) {
                is TreeState.Success -> {
                    state.members.filter { it.familyId == selectedFamily?.id }
                }
                else -> emptyList()
            }
        }
    }.value
    
    // ✅ CORRETO: Callbacks estáveis
    val onMemberClick = remember<(String) -> Unit> {
        { memberId -> viewModel.selectMember(memberId) }
    }
    
    when (treeState) {
        is TreeState.Loading -> LoadingScreen()
        is TreeState.Success -> {
            TreeContent(
                members = filteredMembers,
                onMemberClick = onMemberClick
            )
        }
        is TreeState.Error -> ErrorScreen(
            exception = (treeState as TreeState.Error).exception
        )
    }
}
```

### ❌ ERRADO: Vai recompor toda vez
```kotlin
@Composable
fun BadScreen(viewModel: ViewModel) {
